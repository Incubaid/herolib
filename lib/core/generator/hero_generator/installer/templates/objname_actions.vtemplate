//! ${args.classname} Actions Module
//!
//! This module contains the lifecycle actions for ${args.classname}:
//! - install: Download and install the software
//! - destroy: Remove the installation
@if args.startupmanager
//! - start/stop/restart: Service lifecycle management
@end
@if args.build
//! - build: Compile from source
@end
//!
//! ## Usage
//!
//! These actions are typically invoked via HeroScript:
//!
//! ```heroscript
//! !!${args.name}.install
@if args.startupmanager
//! !!${args.name}.start
@end
//! ```
module ${args.name}

import incubaid.herolib.ui.console
import incubaid.herolib.installers.ulist
@if args.startupmanager
import incubaid.herolib.osal.startupmanager
@end

@if args.startupmanager
^^[params]
pub struct StartArgs {
pub mut:
	reset bool
}

// Returns the list of processes to be managed by the startup manager.
fn startupcmd(self &${args.classname}, args StartArgs) ![]startupmanager.ZProcessNewArgs {
	mut res := []startupmanager.ZProcessNewArgs{}
	_ = args.reset  // TODO: use reset flag if needed

	// Example: Add a process to be managed
	// res << startupmanager.ZProcessNewArgs{
	// 	name: '${args.name}'
	// 	cmd: '${args.name} server'
	// 	reset: args.reset
	// 	env: { 'HOME': '/root' }
	// }
	return res
}

// Performs a health check to verify the service is running correctly.
fn running_check(self &${args.classname}) !bool {
	// Example: HTTP health check
	// url := 'http://127.0.0.1:??{self.port}/health'
	// mut conn := httpconnection.new(name: '${args.name}', url: url)!
	// r := conn.get(prefix: 'health') or { return false }
	// return r.status == 200
	return false
}

// Hook called before the service starts.
fn start_pre(self &${args.classname}) ! {
}

// Hook called after the service starts successfully.
fn start_post(self &${args.classname}) ! {
}

// Hook called before the service stops.
fn stop_pre(self &${args.classname}) ! {
}

// Hook called after the service stops.
fn stop_post(self &${args.classname}) ! {
}
@end


// Destroys the ${args.name} installation.
@if args.startupmanager
// Stops the service and removes all installed files.
fn destroy(mut self ${args.classname}) ! {
	self.stop()!
	// TODO: Implement cleanup logic
}
@else
// Removes all installed files and configuration.

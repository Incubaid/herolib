module ${args.name}

import incubaid.herolib.core.base

// Test factory functions for ${args.classname}
fn testsuite_begin() ! {
	base.context(reload: true)!
}

fn test_new_and_get() ! {
	// Create new instance
	mut obj := new(name: 'test_instance', create: true)!
	assert obj.name == 'test_instance'

	// Get existing instance
	mut obj2 := get(name: 'test_instance')!
	assert obj2.name == 'test_instance'
}

fn test_set_and_exists() ! {
	// Create and set instance
	mut obj := ${args.classname}{
		name: 'test_set'
	}
	set(obj)!

	// Check exists
	assert exists(name: 'test_set')! == true
	assert exists(name: 'nonexistent')! == false
}

fn test_list() ! {
	// Create test instances
	new(name: 'list_test_1', create: true)!
	new(name: 'list_test_2', create: true)!

	// List all instances
	instances := list()!
	assert instances.len >= 2
}

fn test_delete() ! {
	// Create instance
	new(name: 'to_delete', create: true)!
	assert exists(name: 'to_delete')! == true

	// Delete instance
	delete(name: 'to_delete')!
	assert exists(name: 'to_delete')! == false
}

fn test_heroscript_loads() ! {
	heroscript := '
!!${args.name}.configure
    name: "heroscript_test"
    host: "localhost"
    port: 8080
'
	obj := heroscript_loads(heroscript)!
	assert obj.name == 'heroscript_test'
	assert obj.host == 'localhost'
	assert obj.port == 8080
}

fn test_install() ! {
	mut obj := get(name: 'install_test', create: true)!

	// Test install (may fail if dependencies not met - that's expected in test environment)
	obj.install() or {
		// Installation may fail in test environment, log but don't fail test
		println('Install test skipped: ??{err}')
		return
	}

	// Verify installed
	assert obj.installed()! == true
}

@if args.startupmanager
fn test_lifecycle() ! {
	mut obj := get(name: 'lifecycle_test', create: true)!

	// Skip if not installed
	if !obj.installed()! {
		println('Lifecycle test skipped: not installed')
		return
	}

	// Test start
	obj.start()!
	assert obj.running()! == true

	// Test stop
	obj.stop()!
	assert obj.running()! == false

	// Test restart
	obj.start()!
	obj.restart()!
	assert obj.running()! == true

	// Cleanup
	obj.stop()!
}
@end

fn test_destroy() ! {
	mut obj := get(name: 'destroy_test', create: true)!

	// Install first (skip if fails)
	obj.install() or {
		println('Destroy test skipped: install failed')
		return
	}

	// Destroy
	obj.destroy()!

	// Verify destroyed
	assert obj.installed()! == false
}

fn testsuite_end() ! {
	// Cleanup test instances
	for name in ['test_instance', 'test_set', 'list_test_1', 'list_test_2', 'heroscript_test', 'install_test', 'lifecycle_test', 'destroy_test'] {
		delete(name: name) or {}
	}
}

